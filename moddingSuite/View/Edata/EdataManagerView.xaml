<Window
    x:Class="moddingSuite.View.Edata.EdataManagerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Edata="clr-namespace:moddingSuite.View.Edata"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:edata="clr-namespace:moddingSuite.ViewModel.Edata"
    xmlns:extension="clr-namespace:moddingSuite.View.Extension"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:view="clr-namespace:moddingSuite.View"
    Title="Wargame Modding Suite"
    Width="1367.591"
    Height="729.885"
    Icon="{StaticResource PackageFileIcon}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.Resources>
        <extension:BindingProxy x:Key="Proxy" Data="{Binding}" />
    </Window.Resources>
    <Grid>
        <UniformGrid
            Margin="0,0,0,20"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Panel.ZIndex="1000"
            d:IsHidden="True"
            Background="White"
            Visibility="{Binding Path=IsUIBusy, Converter={StaticResource BoolToVisibilityCollapsedConverter}}">
            <view:SpinningWheel
                x:Name="wheel"
                Direction="CW"
                DotCount="21"
                DotRadius="7"
                IsSpinning="True"
                Radius="36"
                Speed="1.25"
                SymmetricalArrange="True" />
        </UniformGrid>

        <Grid Panel.ZIndex="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="22" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="5" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Menu
                Grid.Row="0"
                Grid.ColumnSpan="2"
                IsMainMenu="True">
                <MenuItem Header="_File">
                    <MenuItem Command="{Binding Path=OpenFileCommand}" Header="_Open" />
                    <MenuItem Command="{Binding Path=CloseFileCommand}" Header="_Close" />

                </MenuItem>
                <MenuItem Header="_Settings">
                    <MenuItem Command="{Binding Path=ChangeExportPathCommand}" Header="Change _export path" />
                    <MenuItem Command="{Binding Path=ChangeWargamePathCommand}" Header="Change _Wargame path" />
                    <MenuItem Command="{Binding Path=ChangePythonPathCommand}" Header="Change _Python path" />
                    <MenuItem Command="{Binding Path=ChangeQuickBmsPathCommand}" Header="Change _QuickBMS exe" />
                    <MenuItem Command="{Binding Path=ChangeQuickBmsScriptPathCommand}" Header="Change QuickBMS _script" />
                </MenuItem>
            </Menu>

            <ToolBar Grid.Row="1" Style="{StaticResource Vs2010StyleToolBar}">
                <Menu>
                    <MenuItem ToolTip="Raw data">
                        <MenuItem.Header>
                            <Image Source="{StaticResource ExtractRawIcon}" />
                        </MenuItem.Header>
                        <MenuItem Command="{Binding ExportRawCommand}" Header="Export">
                            <MenuItem.Icon>
                                <Image Source="{StaticResource ExportIcon}" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Command="{Binding ReplaceRawCommand}" Header="Replace">
                            <MenuItem.Icon>
                                <Image Source="{StaticResource ImportIcon}" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>
                </Menu>
                <!--<Button ToolTip="Export raw data" Command="{Binding Path=ExportRawCommand}">
                <Image Source="{StaticResource ExtractRawIcon}"  />
            </Button>-->
                <Button
                    Command="{Binding Path=ExportNdfCommand}"
                    Style="{DynamicResource ButtonStyle1}"
                    ToolTip="Export Uncompressed NDF content">
                    <Image Width="16 " Source="{StaticResource ExtractZipedPartIcon}" />
                </Button>

                <Menu>
                    <MenuItem ToolTip="Textures">
                        <MenuItem.Header>
                            <Image Source="{StaticResource TextureIcon}" />
                        </MenuItem.Header>
                        <MenuItem Command="{Binding ExportTextureCommand}" Header="Export">
                            <MenuItem.Icon>
                                <Image Source="{StaticResource ExportIcon}" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Command="{Binding ReplaceTextureCommand}" Header="Replace">
                            <MenuItem.Icon>
                                <Image Source="{StaticResource ImportIcon}" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>
                </Menu>

                <Menu>
                    <MenuItem ToolTip="Sounds">
                        <MenuItem.Header>
                            <Image Source="{StaticResource SoundIcon}" />
                        </MenuItem.Header>
                        <MenuItem Command="{Binding ExportSoundCommand}" Header="Export">
                            <MenuItem.Icon>
                                <Image Source="{StaticResource ExportIcon}" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Command="{Binding ReplaceSoundCommand}" Header="Replace">
                            <MenuItem.Icon>
                                <Image Source="{StaticResource ImportIcon}" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>
                </Menu>

                <Separator />

                <Button
                    Command="{Binding EditNdfbinCommand}"
                    Style="{DynamicResource ButtonStyle1}"
                    ToolTip="Edit ndf file">
                    <Image Source="{StaticResource OpenDetailsIcon}" />
                </Button>
                <Button
                    Command="{Binding EditMeshCommand}"
                    Style="{DynamicResource ButtonStyle1}"
                    ToolTip="Edit mesh file">
                    <Image Source="{StaticResource MeshFileIcon}" />
                </Button>
                <Button
                    Command="{Binding EditTradFileCommand}"
                    Style="{DynamicResource ButtonStyle1}"
                    ToolTip="Edit dictionary">
                    <Image Source="{StaticResource OpenDictionayIcon}" />
                </Button>
                <!--<Button ToolTip="View Wmv file" Command="{Binding PlayMovieCommand}"  Style="{DynamicResource ButtonStyle1}">
                        <Image Source="{StaticResource OpenMovieIcon}" />
                    </Button>-->
                <Separator />
                <Button
                    Command="{Binding AboutUsCommand}"
                    Style="{DynamicResource ButtonStyle1}"
                    ToolTip="About">
                    <Image Source="{StaticResource AboutIcon}" />
                </Button>

            </ToolBar>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="300" />
                </Grid.ColumnDefinitions>

                <TabControl IsSynchronizedWithCurrentItem="True" ItemsSource="{Binding Path=OpenFiles}">
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <Button
                                    x:Name="close_btn"
                                    Height="15"
                                    Margin="15,0,0,0"
                                    Padding="2"
                                    Command="{Binding Path=CloseCommand}"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource ButtonStyle1}">
                                    <Path
                                        x:Name="Cross"
                                        Width="10"
                                        Height="10"
                                        Data="M0,0 L1,1 M0,1 L1,0"
                                        Stretch="Fill"
                                        Stroke="White"
                                        StrokeThickness="1" />
                                </Button>
                                <TextBlock Text="{Binding Path=HeaderText}" ToolTip="{Binding Path=LoadedFile}" />
                            </DockPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate>
                            <Edata:EdataFileView />
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
                <GridSplitter
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="White" />

                <TabControl Grid.Column="2">
                    <TabItem Header="Workspace">
                        <TreeView extension:TreeViewExtension.SelectItemOnRightClick="true" ItemsSource="{Binding Workspace.Root}">
                            <TreeView.Resources>
                                <ContextMenu x:Key="workspaceContextMenu">
                                    <MenuItem
                                        Command="{Binding Data.ReplaceRawFromWorkspaceCommand, Source={StaticResource Proxy}}"
                                        CommandParameter="{Binding Info.FullName}"
                                        Header="Import raw file">
                                        <MenuItem.Icon>
                                            <Image Source="{StaticResource ImportIcon}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem
                                        Command="{Binding Data.ReplaceSoundFromWorkspaceCommand, Source={StaticResource Proxy}}"
                                        CommandParameter="{Binding Info.FullName}"
                                        Header="Import as Ess sound file">
                                        <MenuItem.Icon>
                                            <Image Source="{StaticResource ImportIcon}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem
                                        Command="{Binding Data.ReplaceTextureFromWorkspaceCommand, Source={StaticResource Proxy}}"
                                        CommandParameter="{Binding Info.FullName}"
                                        Header="Import as tgv texture file">
                                        <MenuItem.Icon>
                                            <Image Source="{StaticResource ImportIcon}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem
                                        Command="{Binding Data.AddNewFileCommand, Source={StaticResource Proxy}}"
                                        CommandParameter="{Binding}"
                                        Header="Open as Edata Container">
                                        <MenuItem.Icon>
                                            <Image Source="{StaticResource OpenEdataPackageIcon}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>

                                <HierarchicalDataTemplate DataType="{x:Type edata:FileViewModel}">
                                    <Grid ContextMenu="{StaticResource workspaceContextMenu}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Image Height="16" Source="{StaticResource GenericFileIcon}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="5,2,2,2"
                                            Text="{Binding Name}" />
                                    </Grid>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </TabItem>
                    <TabItem Header="Gamespace">
                        <DockPanel LastChildFill="True">
                            <StackPanel Margin="4,2,4,4" DockPanel.Dock="Top">
                                <CheckBox
                                    Content="Show only ZZ_#.dat files"
                                    IsChecked="{Binding Gamespace.ShowOnlyZzDatFiles}" />
                                <DockPanel Margin="0,4,0,0" LastChildFill="True">
                                    <Button
                                        Width="70"
                                        Margin="6,0,0,0"
                                        Command="{Binding SearchInZzDatCommand}"
                                        Content="Search"
                                        DockPanel.Dock="Right" />
                                    <TextBox Text="{Binding ZzDatSearchQuery, UpdateSourceTrigger=PropertyChanged}">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding SearchInZzDatCommand}" />
                                        </TextBox.InputBindings>
                                        <TextBox.ToolTip>
                                            Search file/path name inside all ZZ_*.dat packages
                                        </TextBox.ToolTip>
                                    </TextBox>
                                </DockPanel>
                                <WrapPanel Margin="0,4,0,0">
                                    <Button
                                        Width="145"
                                        Margin="0,0,6,0"
                                        Command="{Binding BuildUnifiedZzVirtualViewCommand}"
                                        Content="Build Virtual ZZ View" />
                                    <Button
                                        Width="120"
                                        Margin="0,0,6,0"
                                        Command="{Binding ExportSelectedFromUnifiedZzCommand}"
                                        Content="Export Selected" />
                                    <Button
                                        Width="160"
                                        Command="{Binding ExtractUnifiedZzToFolderCommand}"
                                        Content="Extract Output to Folder" />
                                </WrapPanel>
                                <TextBlock
                                    Margin="0,4,0,0"
                                    Foreground="#FF7A5A00"
                                    Text="Note: Extraction may take 1-2 hours and requires 40+ GB of free disk space."
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    Text="{Binding UnifiedZzStatusText}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <ListBox
                                Height="120"
                                Margin="4,0,4,4"
                                DockPanel.Dock="Top"
                                ItemsSource="{Binding ZzDatSearchResults}" />
                            <Grid Margin="4,0,4,4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="220" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <GroupBox Header="Unified ZZ Virtual">
                                    <TreeView
                                        x:Name="UnifiedZzTree"
                                        extension:TreeViewExtension.SelectItemOnRightClick="true"
                                        extension:TreeViewMultiSelectBehavior.EnableMultiSelect="True"
                                        extension:TreeViewMultiSelectBehavior.SelectedItems="{Binding SelectedUnifiedZzNodes}"
                                        ItemsSource="{Binding UnifiedZzRootNodes}"
                                        SelectedItemChanged="UnifiedZzTree_SelectedItemChanged">
                                        <TreeView.ItemContainerStyle>
                                            <Style TargetType="{x:Type TreeViewItem}">
                                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                            </Style>
                                        </TreeView.ItemContainerStyle>
                                        <TreeView.Resources>
                                            <HierarchicalDataTemplate DataType="{x:Type edata:VirtualNodeViewModel}" ItemsSource="{Binding Children}">
                                                <Border
                                                    x:Name="UnifiedNodeSelectionBorder"
                                                    Margin="1,0,1,0"
                                                    Padding="1"
                                                    Background="Transparent"
                                                    CornerRadius="2">
                                                    <Grid>
                                                        <Grid.InputBindings>
                                                            <MouseBinding
                                                                Command="{Binding Path=Data.OpenUnifiedZzNodeCommand, Source={StaticResource Proxy}}"
                                                                CommandParameter="{Binding}"
                                                                MouseAction="LeftDoubleClick" />
                                                        </Grid.InputBindings>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Image
                                                            x:Name="UnifiedNodeIcon"
                                                            Height="16"
                                                            Source="{StaticResource GenericFileIcon}" />
                                                        <TextBlock
                                                            x:Name="UnifiedNodeText"
                                                            Grid.Column="1"
                                                            Margin="5,1,2,1"
                                                            Text="{Binding DisplayName}" />
                                                    </Grid>
                                                </Border>
                                                <HierarchicalDataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsNdfbin}" Value="True">
                                                        <Setter TargetName="UnifiedNodeIcon" Property="Source" Value="{StaticResource ScriptIcon}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                        <Setter TargetName="UnifiedNodeIcon" Property="Source" Value="{StaticResource VsFolderIcon}" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsFolder}" Value="True" />
                                                            <Condition Binding="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType={x:Type TreeViewItem}}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter TargetName="UnifiedNodeIcon" Property="Source" Value="{StaticResource VsFolderIconOpen}" />
                                                    </MultiDataTrigger>
                                                    <DataTrigger Binding="{Binding IsMultiSelected}" Value="True">
                                                        <Setter TargetName="UnifiedNodeSelectionBorder" Property="Background" Value="#FF2D7D9A" />
                                                        <Setter TargetName="UnifiedNodeText" Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                </HierarchicalDataTemplate.Triggers>
                                            </HierarchicalDataTemplate>
                                        </TreeView.Resources>
                                    </TreeView>
                                </GroupBox>

                                <GridSplitter
                                    Grid.Row="1"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Background="White" />

                                <GroupBox Grid.Row="2" Header="Filesystem">
                                    <TreeView extension:TreeViewExtension.SelectItemOnRightClick="true" ItemsSource="{Binding Gamespace.DisplayRoot}">
                                        <TreeView.Resources>
                                            <DataTemplate DataType="{x:Type edata:FileViewModel}">
                                                <Grid>
                                                    <Grid.InputBindings>
                                                        <MouseBinding
                                                            Command="{Binding Path=Data.AddNewFileCommand, Source={StaticResource Proxy}}"
                                                            CommandParameter="{Binding}"
                                                            MouseAction="LeftDoubleClick" />
                                                    </Grid.InputBindings>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Image Height="16" Source="{StaticResource GenericFileIcon}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Margin="5,2,2,2"
                                                        Text="{Binding Name}" />
                                                </Grid>
                                            </DataTemplate>
                                        </TreeView.Resources>
                                    </TreeView>
                                </GroupBox>
                            </Grid>
                        </DockPanel>
                    </TabItem>
                </TabControl>
            </Grid>

            <Grid
                Grid.Row="3"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="White" />

            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Margin="4,2,4,2"
                    Padding="4"
                    BorderBrush="#FFB0B0B0"
                    BorderThickness="1"
                    Visibility="{Binding IsExtractInProgress, Converter={StaticResource BoolToVisibilityCollapsedConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            Text="{Binding ExtractProgressText}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap"
                            VerticalAlignment="Center" />
                        <ProgressBar
                            Grid.Column="0"
                            Height="16"
                            Maximum="100"
                            Minimum="0"
                            Value="{Binding ExtractPercent}" />
                    </Grid>
                </Border>

                <TabControl Grid.Row="1">
                    <TabItem VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
                        <TabItem.Header>
                            <DockPanel>
                                <ToggleButton
                                    x:Name="OutputPushPin"
                                    Height="15"
                                    Margin="15,0,0,0"
                                    Padding="0"
                                    DockPanel.Dock="Right"
                                    IsChecked="True"
                                    Style="{StaticResource ToggleButtonStyle1}">
                                    <Image Source="{StaticResource PushPinIcon}" />
                                </ToggleButton>
                                <TextBlock Text="Output" />
                            </DockPanel>
                        </TabItem.Header>
                        <TextBox
                            IsReadOnly="True"
                            Text="{Binding Path=StatusText}"
                            TextWrapping="WrapWithOverflow"
                            Visibility="{Binding IsChecked, ElementName=OutputPushPin, Converter={StaticResource BoolToVisibilityCollapsedConverter}}" />
                    </TabItem>
                </TabControl>
            </Grid>

            <!--<StatusBar Grid.Row="3">
                <TextBlock Text="{Binding Path=StatusText}" />
            </StatusBar>-->
        </Grid>
    </Grid>
</Window>
